{
    "compilerOptions": {
        "module": "esnext",
        "moduleResolution": "bundler",
        "target": "es2023",
        "strict": true,
        "esModuleInterop": true,
        "ignoreDeprecations": "6.0",
        "outDir": "./dist",
        "types": ["node"],
        "skipLibCheck": true,
    },
    "include": ["**/*.ts"],
    "exclude": ["node_modules", "dist"]
}